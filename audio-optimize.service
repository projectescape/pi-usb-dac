[Unit]
Description=Audio optimization (disable WiFi power save + performance governor)
After=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c 'iw dev wlan0 set power_save off 2>/dev/null; echo performance | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null 2>&1'
ExecStop=/bin/bash -c 'echo ondemand | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null 2>&1'

[Install]
WantedBy=multi-user.target
